{
  "manifest_version": 3,
  "name": "Char Paster",
  "version": "1.0.0",
  "description": "Right-click any text field and type text character by character to bypass paste restrictions.",
  "browser_specific_settings": {
    "gecko": {
      "id": "{b8f5e9a2-c7d1-4e3f-a6b0-1d2e3f4a5b6c}",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "menus",
    "clipboardRead"
  ],
  "background": {
    "scripts": ["background/background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    }
  },
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  }
}
