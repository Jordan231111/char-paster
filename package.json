{
  "name": "char-paster",
  "version": "1.0.1",
  "private": true,
  "description": "Firefox extension to type text character by character, bypassing paste restrictions.",
  "scripts": {
    "start": "web-ext run --firefox=firefox --browser-console",
    "build": "web-ext build --overwrite-dest",
    "sign": "web-ext sign --channel=unlisted",
    "lint": "web-ext lint"
  },
  "devDependencies": {
    "web-ext": "^10.1.0"
  }
}
